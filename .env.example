# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/citydb
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=citydb

# Security & Authentication
SECRET_KEY=generate-a-secure-random-key-here
JWT_SECRET=generate-a-secure-jwt-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Notifications (Brevo API)
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
BREVO_SENDER_EMAIL=your-verified-email@gmail.com
